{
  "name": "EmergencyContact",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Contact name"
    },
    "relationship": {
      "type": "string",
      "description": "Relationship to user (parent, partner, friend, etc.)"
    },
    "phone": {
      "type": "string",
      "description": "Phone number"
    },
    "email": {
      "type": "string",
      "description": "Email address"
    },
    "can_view_data": {
      "type": "boolean",
      "description": "Whether this contact can see health data",
      "default": false
    },
    "notify_on_crisis": {
      "type": "boolean",
      "description": "Whether to notify this contact in crisis situations",
      "default": true
    }
  },
  "required": [
    "name",
    "phone"
  ]
}